# Database
# For local dev:  postgresql://clearvote:clearvote@localhost:5432/clearvote?schema=public
# For docker:     postgresql://clearvote:clearvote@db:5432/clearvote?schema=public
DATABASE_URL="postgresql://clearvote:clearvote@localhost:5432/clearvote?schema=public"

# Auth (NextAuth.js secret — generate with: openssl rand -base64 32)
AUTH_SECRET="change-me-to-a-random-secret"

# Docker
# Port the app listens on inside the container (default 3000)
# Map this to any host port via APP_PORT in docker-compose
# APP_PORT=3000
