# Copy this to .env and fill in your values.
# Required everywhere: DATABASE_URL, AUTH_SECRET (see src/lib/env.ts).

# ── Database ─────────────────────────────────────────────────────────
# Local dev and the Prisma CLI read this full URL directly.
#   Local dev:  postgresql://clearvote:clearvote@localhost:5432/clearvote?schema=public
# NOTE: the prod compose file (docker-compose.prod.yml) builds DATABASE_URL
# from DB_USER/DB_PASSWORD/DB_NAME instead — there you set those parts and
# leave DATABASE_URL unset (see the Docker production section below).
DATABASE_URL="postgresql://clearvote:clearvote@localhost:5432/clearvote?schema=public"

# ── Auth ─────────────────────────────────────────────────────────────
# NextAuth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-secret"

# ── App ──────────────────────────────────────────────────────────────
# Public base URL, used to build links in emails. Required in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Email ────────────────────────────────────────────────────────────
# Which provider to use: "resend" or "smtp".
# Defaults to "resend" if RESEND_API_KEY is set, otherwise "smtp".
EMAIL_PROVIDER="resend"

# Option 1: Resend (recommended for production)
RESEND_API_KEY="re_xxxxxxxx"

# Option 2: SMTP (for local testing or self-hosted)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Clearvote <no-reply@example.com>"

# ── Docker (docker-compose.yml) ──────────────────────────────────────
# Host port to expose the app on (default 3000).
# APP_PORT=3000

# ── Docker production (docker-compose.prod.yml) ──────────────────────
# In prod, DATABASE_URL is assembled from these parts — do NOT set
# DATABASE_URL above when using the prod compose file.
# The file refuses to start without DB_PASSWORD, APP_IMAGE, AUTH_SECRET,
# and NEXT_PUBLIC_APP_URL. The dev compose file hardcodes the DB
# credentials, so these are prod-only.
# APP_IMAGE=ghcr.io/yourorg/clearvote:latest
# DB_USER=clearvote
# DB_PASSWORD=change-me-in-production
# DB_NAME=clearvote
