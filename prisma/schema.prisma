generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  description String?
  slug        String   @unique
  createdAt   DateTime @default(now())

  members OrganizationMember[]
  polls   Poll[]
}

model OrganizationMember {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           String   @default("member") // admin | member
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

  memberships  OrganizationMember[]
  polls        Poll[]
  rolls        VoterRoll[]
  principalFor Proxy[]  @relation("Principal")
  proxyFor     Proxy[]  @relation("Proxy")
}

model Poll {
  id             String        @id @default(uuid())
  title          String
  description    String?
  slug           String        @unique
  seats          Int           @default(1)
  votingMethod   String        @default("rcv")
  threshold      Int           @default(50)
  status         String        @default("draft")
  creatorId      String?
  organizationId String?
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  creator      User?         @relation(fields: [creatorId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  options      PollOption[]
  ballots      Ballot[]
  tokens       VoterToken[]
  rolls        VoterRoll[]
  auditLogs    AuditLog[]
  proxies      Proxy[]
}

model PollOption {
  id        String   @id @default(uuid())
  pollId    String
  label     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@index([pollId])
}

model Ballot {
  id          String   @id @default(uuid())
  pollId      String
  rankings    Json
  receiptCode String   @unique
  castAt      DateTime @default(now())
  verifiedAt  DateTime?

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@index([pollId])
}

model VoterToken {
  id        String    @id @default(uuid())
  pollId    String
  token     String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, token])
  @@index([pollId])
}

model VoterRoll {
  id        String    @id @default(uuid())
  pollId    String
  userId    String
  hasVoted  Boolean   @default(false)
  votedAt   DateTime?

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([pollId, userId])
  @@index([pollId])
}

model AuditLog {
  id        String   @id @default(uuid())
  pollId    String
  action    String
  detail    String?
  createdAt DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@index([pollId])
}

model Proxy {
  id          String   @id @default(uuid())
  pollId      String
  principalId String
  proxyId     String
  createdAt   DateTime @default(now())

  poll      Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  principal User @relation("Principal", fields: [principalId], references: [id])
  proxy     User @relation("Proxy", fields: [proxyId], references: [id])

  @@unique([pollId, principalId])
  @@index([pollId])
}
