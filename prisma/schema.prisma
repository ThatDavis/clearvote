generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  description String?
  slug        String   @unique
  createdAt   DateTime @default(now())

  members   OrganizationMember[]
  invites   OrganizationInvite[]
  polls     Poll[]
  contests  Contest[]
  elections Election[]
}

model OrganizationMember {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           String   @default("member") // admin | member
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model OrganizationInvite {
  id             String   @id @default(uuid())
  email          String
  organizationId String
  tokenHash      String   @unique
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([email, organizationId])
  @@index([organizationId])
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String
  passwordHash   String
  createdAt      DateTime  @default(now())

  memberships        OrganizationMember[]
  polls              Poll[]
  contests           Contest[]
  rolls              VoterRoll[]
  electionRolls      ElectionVoterRoll[]
  elections          Election[]
  verificationTokens EmailVerificationToken[]
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Poll {
  id             String        @id @default(uuid())
  title          String
  description    String?
  slug           String        @unique
  seats          Int           @default(1)
  votingMethod   String        @default("rcv")
  threshold      Int           @default(50)
  status         String        @default("draft")
  creatorId      String?
  organizationId String?
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  creator      User?         @relation(fields: [creatorId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  options      PollOption[]
  ballots      Ballot[]
  tokens       VoterToken[]
  rolls        VoterRoll[]
  auditLogs    AuditLog[]
}

model PollOption {
  id        String   @id @default(uuid())
  pollId    String
  label     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@index([pollId])
}

model Ballot {
  id          String   @id @default(uuid())
  pollId      String
  rankings    Json
  receiptCode String   @unique
  castAt      DateTime @default(now())
  verifiedAt  DateTime?

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@index([pollId])
}

model VoterToken {
  id         String    @id @default(uuid())
  pollId     String
  tokenHash  String
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, tokenHash])
  @@index([pollId])
}

model VoterRoll {
  id        String    @id @default(uuid())
  pollId    String
  userId    String
  hasVoted  Boolean   @default(false)
  votedAt   DateTime?

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([pollId, userId])
  @@index([pollId])
}

model AuditLog {
  id        String   @id @default(uuid())
  pollId    String
  action    String
  detail    String?
  createdAt DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@index([pollId])
}

model Contest {
  id             String   @id @default(uuid())
  title          String
  description    String?
  slug           String   @unique
  votingMethod   String   @default("rcv")
  seats          Int      @default(1)
  threshold      Int      @default(50)
  status         String   @default("draft")
  contestOrder   Int      @default(0)
  creatorId      String?
  organizationId String?
  electionId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  creator      User?         @relation(fields: [creatorId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  election     Election      @relation(fields: [electionId], references: [id], onDelete: Cascade)
  options      ContestOption[]
  ballots      ContestBallot[]

  @@index([electionId])
}

model ContestOption {
  id        String   @id @default(uuid())
  contestId String
  label     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([contestId])
}

model ContestBallot {
  id          String   @id @default(uuid())
  contestId   String
  rankings    Json
  receiptCode String   @unique
  castAt      DateTime @default(now())
  verifiedAt  DateTime?

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([contestId])
}

model Election {
  id             String    @id @default(uuid())
  title          String
  description    String?
  slug           String    @unique
  status         String    @default("draft")
  startsAt       DateTime?
  endsAt         DateTime?
  creatorId      String?
  organizationId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  contests   Contest[]
  tokens     ElectionVoterToken[]
  rolls      ElectionVoterRoll[]
  receipts   ElectionReceipt[]
  auditLogs  ElectionAuditLog[]

  creator      User?         @relation(fields: [creatorId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
}

model ElectionVoterToken {
  id            String    @id @default(uuid())
  electionId    String
  tokenHash     String
  ballotStyleId String?
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@unique([electionId, tokenHash])
  @@index([electionId])
}

model ElectionVoterRoll {
  id            String    @id @default(uuid())
  electionId    String
  userId        String
  ballotStyleId String?
  hasVoted      Boolean   @default(false)
  votedAt       DateTime?

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([electionId, userId])
  @@index([electionId])
}

model ElectionReceipt {
  id          String   @id @default(uuid())
  electionId  String
  receiptCode String   @unique
  castAt      DateTime @default(now())

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@index([electionId])
}

model ElectionAuditLog {
  id        String   @id @default(uuid())
  electionId String
  action    String
  detail    String?
  createdAt DateTime @default(now())

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@index([electionId])
}


