generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  users User[]
  polls Poll[]
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  name           String
  passwordHash   String
  organizationId String?
  createdAt      DateTime      @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  polls        Poll[]
  ballots      Ballot[]
  rolls        VoterRoll[]
}

model Poll {
  id             String        @id @default(uuid())
  title          String
  description    String?
  slug           String        @unique
  seats          Int           @default(1)
  status         String        @default("draft")
  creatorId      String?
  organizationId String?
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  creator      User?         @relation(fields: [creatorId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  options      PollOption[]
  ballots      Ballot[]
  tokens       VoterToken[]
  rolls        VoterRoll[]
}

model PollOption {
  id        String   @id @default(uuid())
  pollId    String
  label     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@index([pollId])
}

model Ballot {
  id          String   @id @default(uuid())
  pollId      String
  userId      String?
  voterToken  String
  rankings    Json
  receiptCode String   @unique
  castAt      DateTime @default(now())
  verifiedAt  DateTime?

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@unique([pollId, voterToken])
  @@index([pollId])
}

model VoterToken {
  id        String    @id @default(uuid())
  pollId    String
  token     String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, token])
  @@index([pollId])
}

model VoterRoll {
  id     String @id @default(uuid())
  pollId String
  userId String

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([pollId, userId])
  @@index([pollId])
}
